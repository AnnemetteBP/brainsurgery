import List

update :: ?Cache -> Tensor[B,H,T,D] -> Tensor[B,H,T,D] -> (Tensor[B,H,T,D], Tensor[B,H,T,D], ?Cache)
update past k v = _cache_update past k v

seq_len :: ?Tensor[B,H,T,D] -> I
seq_len k = _cache_seq_len k

init :: Cache
init = List.init

index :: ?Cache -> I -> ?CacheLayer
index = List.index

append :: ?Cache -> CacheLayer -> ?Cache
append = List.append

past_length :: ?Cache -> I
past_length cache = do
  first <- _list_index cache 0
  return _cache_seq_len first
