# Synapse YAML Formal Grammar (EBNF-like)
# Notes:
# - This grammar specifies the structural contract for synapse: 1 specs.
# - YAML scalar typing is represented abstractly as terminals (String, Int, Float, Bool, Null).
# - Expression scalars are represented as Expr and may be literals/symbol refs/arithmetic strings.

SynapseSpec        = Mapping("synapse" ":" 1, "model" ":" ModelSpec) ;

ModelSpec          = Mapping(
                      ["name" ":" String],
                      ["model_type" ":" String],
                      ["architectures" ":" ListOfString],
                      ["symbols" ":" SymbolTable],
                      ["params" ":" Mapping],
                      ["inputs" ":" InputTable],
                      ["blocks" ":" BlockTable],
                      "graph" ":" Graph,
                      "outputs" ":" OutputTable,
                      ["naming" ":" NamingSpec]
                    ) ;

NamingSpec         = Mapping(["root" ":" String]) ;

SymbolTable        = Mapping({ SymbolName ":" (Int | Null) }) ;
InputTable         = Mapping({ VarName ":" InputSpec }) ;
OutputTable        = Mapping({ VarName ":" OutputRef }) ;
BlockTable         = Mapping({ BlockName ":" BlockSpec }) ;

InputSpec          = Mapping(
                      ["shape" ":" ShapeSpec],
                      ["dtype" ":" DType],
                      ["optional" ":" Bool]
                    ) ;

BlockSpec          = Mapping(
                      ["inputs" ":" InputTable],
                      "graph" ":" Graph,
                      "outputs" ":" OutputTable
                    ) ;

Graph              = SequenceOf(NodeItem) ;
NodeItem           = Mapping(NodeName ":" NodeSpec) ;

NodeSpec           = ControlRepeat
                   | BlockUse
                   | NestedGraph
                   | OpNode ;

ControlRepeat      = Mapping(
                      "op" ":" "repeat",
                      "var" ":" VarName,
                      "range" ":" Expr,
                      "body" ":" Graph,
                      ["when" ":" Expr]
                    ) ;

BlockUse           = Mapping(
                      "use" ":" BlockName,
                      ["in" ":" BindingIn],
                      ["out" ":" BindingOut],
                      ["when" ":" Expr]
                    ) ;

NestedGraph        = Mapping(
                      "graph" ":" Graph,
                      ["when" ":" Expr]
                    ) ;

OpNode             = Mapping(
                      "op" ":" OpName,
                      ["in" ":" InputRef],
                      ["out" ":" OutputRefField],
                      { OpAttrKey ":" OpAttrValue },
                      ["when" ":" Expr]
                    ) ;

BindingIn          = Mapping({ VarName ":" ExprOrVar }) ;
BindingOut         = Mapping({ VarName ":" VarName }) ;

OutputRefField     = VarName | SequenceOf(VarName) ;
OutputRef          = VarName | Mapping("from" ":" VarName) ;

InputRef           = VarName
                   | SequenceOf(VarNameOrExpr) ;

ShapeSpec          = SequenceOf(ExprOrVar) ;

OpName             = "embedding" | "linear" | "layernorm" | "rmsnorm"
                   | "activation" | "softmax" | "topk" | "zeros_like"
                   | "add" | "mul" | "arange_positions" | "split_last"
                   | "reshape_heads" | "apply_rope_pair"
                   | "kv_seq_len" | "repeat_kv" | "merge_heads" | "attention"
                   | "causal_mask" | "moe_select_tokens"
                   | "moe_scatter_add" | "index" | "init_list" | "append"
                   | "kv_cache_update" | "coalesce" ;

Expr               = Int | Float | Bool | Null | SymbolName | VarName | ExprString ;
ExprOrVar          = Expr ;
VarNameOrExpr      = VarName | Expr ;

SymbolName         = Identifier ;
BlockName          = Identifier ;
NodeName           = Identifier ;
VarName            = Identifier ;
OpAttrKey          = Identifier ;
OpAttrValue        = Scalar | Sequence | Mapping ;

Identifier         = /[A-Za-z_][A-Za-z0-9_\-]*/ ;
ExprString         = String ;
DType              = String ;
ListOfString       = SequenceOf(String) ;

# Abstract YAML terminals
Mapping(...)       = YAML mapping matching declared keys/constraints ;
SequenceOf(X)      = YAML sequence where each element matches X ;
String             = YAML string scalar ;
Int                = YAML integer scalar ;
Float              = YAML float scalar ;
Bool               = YAML boolean scalar ;
Null               = YAML null scalar ;
Scalar             = String | Int | Float | Bool | Null ;
Sequence           = YAML sequence ;
