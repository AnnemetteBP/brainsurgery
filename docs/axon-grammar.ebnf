# Axon Grammar (Current Authoring Form)
#
# Indentation-sensitive (Python-style INDENT/DEDENT tokens).
# "--" starts a comment outside strings.
# Current form intentionally excludes legacy `module ... do` headers and
# `repeat ...` loops; use haskell-style header + `for@...` loops.

program             ::= { top_decl } ;

top_decl            ::= top_const_decl
                      | module_decl
                      ;

top_const_decl      ::= UPPER_IDENT "=" const_expr NEWLINE ;

module_decl         ::= haskell_sig NEWLINE haskell_def NEWLINE INDENT stmt_block DEDENT ;
haskell_sig         ::= IDENT "::" type_expr ;
haskell_def         ::= IDENT ident_list "=" "do" ;

stmt_block          ::= { statement NEWLINE } ;

statement           ::= bind_stmt
                      | return_stmt
                      | for_at_stmt
                      | scope_stmt
                      ;

bind_stmt           ::= bind_targets "<-" expr ;
bind_targets        ::= IDENT { "," IDENT } ;

return_stmt         ::= "return" expr_list ;
expr_list           ::= expr { "," expr } ;

for_at_stmt         ::= "for" [ "@" path ] IDENT "<-" range_expr "do"
                        NEWLINE INDENT stmt_block DEDENT ;
range_expr          ::= "[" expr ".." expr ")"    # half-open
                      | "(" expr ".." expr "]"    # open-closed
                      | "[" expr ".." expr "]"    # closed-closed
                      ;

scope_stmt          ::= ( "scope@" path | "scope" path ) "do"
                        NEWLINE INDENT stmt_block DEDENT ;

expr                ::= ternary_expr ;
ternary_expr        ::= bind_expr [ "?" expr ":" expr_or_tuple ] ;
expr_or_tuple       ::= expr | "(" expr_list ")" ;

bind_expr           ::= pipe_expr { ">>=" lambda_expr } ;
lambda_expr         ::= "\" IDENT "->" expr ;

pipe_expr           ::= additive_expr { "|>" pipe_stage } ;
pipe_stage          ::= call_expr | callable ;

additive_expr       ::= multiplicative_expr { ("+" | "-") multiplicative_expr } ;
multiplicative_expr ::= unary_expr { ("*" | "/" | "%" ) unary_expr } ;
unary_expr          ::= [ "not" | "-" | "+" ] primary_expr ;

primary_expr        ::= call_expr
                      | IDENT
                      | literal
                      | "(" expr ")"
                      ;

call_expr           ::= callable "(" [ arg_list ] ")"
                      | callable bare_args
                      ;

bare_args           ::= bare_arg { bare_arg } ;
bare_arg            ::= kwarg | primary_arg ;
primary_arg         ::= IDENT | literal | "(" expr ")" | list_literal ;

arg_list            ::= arg { "," arg } ;
arg                 ::= kwarg | expr ;
kwarg               ::= IDENT "=" kwarg_value ;
kwarg_value         ::= expr ;

callable            ::= IDENT
                      | IDENT "::" IDENT
                      | IDENT "@" path
                      ;

path                ::= path_segment { "." path_segment } ;
path_segment        ::= IDENT
                      | "{" IDENT "}"
                      ;

type_expr           ::= type_atom { "->" type_atom } ;
type_atom           ::= [ "?" ] type_name [ "[" dim_list "]" ]
                      | "(" type_expr { "," type_expr } ")"
                      ;
type_name           ::= IDENT ;
dim_list            ::= dim_expr { "," dim_expr } ;
dim_expr            ::= IDENT | NUMBER ;

const_expr          ::= expr ;

literal             ::= NUMBER | BOOL | NULL | STRING | list_literal ;
list_literal        ::= "[" [ expr { "," expr } ] "]" ;

ident_list          ::= IDENT { IDENT } ;

IDENT               ::= /[A-Za-z_][A-Za-z0-9_]*/ ;
UPPER_IDENT         ::= /[A-Z][A-Z0-9_]*/ ;
NUMBER              ::= /-?[0-9]+(\.[0-9]+)?([eE][+-]?[0-9]+)?/ ;
BOOL                ::= "true" | "false" ;
NULL                ::= "null" ;
STRING              ::= /"([^"\\]|\\.)*"|'([^'\\]|\\.)*'/ ;
