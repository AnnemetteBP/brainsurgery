D   = 2048   -- hidden dimension
V   = 50304  -- vocab size
L   = 24     -- decoder layers
H   = 32     -- attention heads
FFN = 8192   -- mlp hidden size
C   = 2048   -- effective context for this checkpoint family

import Activations gelu
import Cache

falcon_block :: Tensor[B,S,D] -> Tensor[B,S] -> ?CacheLayer -> (Tensor[B,S,D], ?CacheLayer)
falcon_block x attn_mask past_kv = do
  xn <- layernorm@input_layernorm x dim=D

  a, new_kv <- scope@self_attention do
    qkv <- linear@query_key_value xn dim=(3 * D) bias=true
    q, k, v <- split_qkv_heads qkv heads=H layout=interleaved
    k, v, new_kv <- Cache.update past_kv k v
    causal <- causal_mask q k window=C padding_mask=attn_mask
    pos_bias <- linear_position_bias attn_mask heads=H scale=0.125
    mask <- causal + pos_bias
    a <- attention q k v mask=mask |> merge_heads
    a <- linear@dense a dim=D bias=true
    return a, new_kv

  x <- x + a
  x_mlp <- layernorm@post_attention_layernorm x dim=D
  m <- scope@mlp do
    h <- linear@dense_h_to_4h x_mlp dim=FFN bias=true
    return gelu h |> linear@dense_4h_to_h dim=D bias=true
  x <- x + m
  return x, new_kv

falcon_rw_1b :: TokenIds[B,S] -> Tensor[B,S] -> ?Cache -> ?Bool -> (Tensor[B,S,V], ?Cache)
falcon_rw_1b input_ids attn_mask past_kv use_cache = do
  x <- embedding@transformer.word_embeddings input_ids dim=D
  new_kv <- use_cache ? Cache.init : null
  for@transformer.h i <- [0..L) do
    past_i <- Cache.index past_kv i
    x, new_i <- falcon_block x attn_mask past_i
    new_kv <- Cache.append new_kv new_i
  logits <- layernorm@transformer.ln_f x dim=D |> linear@lm_head dim=V
  return logits, new_kv
