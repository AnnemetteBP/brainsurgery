T   = 1024   -- max sequence length
D   = 768    -- hidden dimensions
L   = 12     -- number of layers
H   = 12     -- number of attention heads
V   = 520257 -- vocab size

import Activations gelu_new

lin :: @Path -> Tensor[B,S,Din] -> I -> Tensor[B,S,dim]
lin@path x dim = linear@path x dim=dim bias=true transpose=true
-- synapse:
--   n_op_1:
--     op: linear
--     out: out_0
--     in: x
--     dim: dim
--     bias: true
--     transpose: true
--     param_base: path

gpt2_block :: Tensor[B,S,D] -> ?Tensor[B,S] -> Tensor[B,S,D]
gpt2_block x attn_mask = do
  x1 <- layernorm@ln_1 x
  -- synapse:
  --   ln_1:
  --     op: layernorm
  --     out: x1
  --     in: x
  --     dim: D
  a <- scope@attn do
    q_lin, k_lin, v_lin <- lin@c_attn x1 3*D |> split parts=3
    -- synapse:
    --   n_use_2:
    --     use: lin
    --     in: {x: x1, dim: 3*D, path: 'attn.c_attn'}
    --     out: {out_0: pipe_1}
    --   n_op_3:
    --     op: split
    --     out: [q_lin, k_lin, v_lin]
    --     in: pipe_1
    --     parts: 3
    q <- reshape_heads q_lin heads=H
    -- synapse:
    --   n_op_4:
    --     op: reshape_heads
    --     out: q
    --     in: q_lin
    --     heads: H
    k <- reshape_heads k_lin heads=H
    -- synapse:
    --   n_op_5:
    --     op: reshape_heads
    --     out: k
    --     in: k_lin
    --     heads: H
    v <- reshape_heads v_lin heads=H
    -- synapse:
    --   n_op_6:
    --     op: reshape_heads
    --     out: v
    --     in: v_lin
    --     heads: H
    causal_attn_mask <- causal_mask q key=k window=T padding_mask=attn_mask
    -- synapse:
    --   n_op_7:
    --     op: causal_mask
    --     out: causal_attn_mask
    --     in: q
    --     key: k
    --     window: T
    --     padding_mask: attn_mask
    return attention q k v backend=sdpa causal=true mask=causal_attn_mask |>
      merge_heads |> lin@c_proj D
    -- synapse:
    --   n_op_9:
    --     op: attention
    --     out: pipe_8
    --     in: [q, k, v]
    --     backend: sdpa
    --     causal: true
    --     mask: causal_attn_mask
    --   n_op_11:
    --     op: merge_heads
    --     out: pipe_10
    --     in: pipe_8
    --   n_use_12:
    --     use: lin
    --     in: {x: pipe_10, dim: D, path: 'attn.c_proj'}
    --     out: {out_0: out_0}
    --   n_op_13:
    --     op: _ir_alias
    --     in: out_0
    --     out: a
  x <- x + a
  -- synapse:
  --   n_op_14:
  --     op: add
  --     out: x
  --     in: [x, a]
  x3 <- layernorm@ln_2 x
  -- synapse:
  --   ln_2:
  --     op: layernorm
  --     out: x3
  --     in: x
  --     dim: D
  m <- scope@mlp do
    return lin@c_fc x3 4*D |> gelu_new |> lin@c_proj D
    -- synapse:
    --   n_use_16:
    --     use: lin
    --     in: {x: x3, dim: 4*D, path: 'mlp.c_fc'}
    --     out: {out_0: pipe_15}
    --   n_op_18:
    --     op: activation
    --     in: pipe_15
    --     out: pipe_17
    --     kind: gelu_new
    --   n_use_19:
    --     use: lin
    --     in: {x: pipe_17, dim: D, path: 'mlp.c_proj'}
    --     out: {out_0: out_0}
    --   n_op_20:
    --     op: _ir_alias
    --     in: out_0
    --     out: m
  return x + m
  -- synapse:
  --   n_op_21:
  --     op: add
  --     out: out_0
  --     in: [x, m]

gpt2 :: TokenIds[B,S] -> ?Tensor[B,S] -> Tensor[B,S,V]
gpt2 input_ids attn_mask = do
  tok <- embedding@wte input_ids dim=D
  -- synapse:
  --   n_op_1:
  --     _op: embedding
  --     _bind: tok
  --     _args: input_ids
  --     dim: D
  --     _params: {weight: wte.weight}
  pos <- arange_positions input_ids attention_mask=attn_mask |> embedding@wpe
  -- synapse:
  --   n_op_3:
  --     _op: arange_positions
  --     _bind: pipe_2
  --     _args: input_ids
  --     attention_mask: attn_mask
  --   n_op_4:
  --     _op: embedding
  --     _bind: pos
  --     _args: pipe_2
  --     _params: {weight: wpe.weight}
  x <- tok + pos
  -- synapse:
  --   n_op_5:
  --     _op: add
  --     _bind: x
  --     _args: [tok, pos]
  for@h i <- [0..L) do
    x <- gpt2_block x attn_mask
    -- synapse:
    --   n_use_4:
    --     use: gpt2_block
    --     in: {x: x, attn_mask: attn_mask}
    --     out: {out_0: x}
  -- synapse:
  --   h:
  --     op: repeat
  --     var: i
  --     range: L
  --     body: [{n_use_4: {use: gpt2_block, in: {x: x, attn_mask: attn_mask}, out: {out_0: x}}}]
  logits <- layernorm@ln_f x |> linear@wte
  -- synapse:
  --   ln_f:
  --     op: layernorm
  --     out: pipe_5
  --     in: x
  --     dim: D
  --   wte:
  --     op: linear
  --     out: logits
  --     in: pipe_5
  --     dim: V
  return logits
