T   = 1024   -- max sequence length
D   = 768    -- hidden dimensions
L   = 12     -- number of layers
H   = 12     -- number of attention heads
V   = 520257 -- vocab size

import Activations gelu_new
import Cache

lin :: @Path -> Tensor[B,S,Din] -> I -> Tensor[B,S,dim]
lin@path x dim = linear@path x dim=dim bias=true transpose=true

gpt2_block :: Tensor[B,S,D] -> ?Tensor[B,S] -> ?Cache -> ?Bool -> (Tensor[B,S,D], ?Cache)
gpt2_block x attn_mask past_kv use_cache = do
  x1 <- layernorm@ln_1 x
  q, k, v <- scope@attn do
    q_lin, k_lin, v_lin <- lin@c_attn x1 3*D |> split parts=3
    q <- reshape_heads q_lin heads=H
    k <- reshape_heads k_lin heads=H
    v <- reshape_heads v_lin heads=H
    return q, k, v
  k_all, v_all, present_kv <- Cache.update past_kv k v when=use_cache
  k_ctx, v_ctx <- Cache.coalesce k_all v_all k v
  a <- scope@attn do
    causal_attn_mask <- causal_mask q key=k_ctx window=T padding_mask=attn_mask
    return attention q k_ctx v_ctx backend=sdpa causal=true mask=causal_attn_mask |>
      merge_heads |> lin@c_proj D
  x <- x + a
  x3 <- layernorm@ln_2 x
  m <- scope@mlp do
    return lin@c_fc x3 4*D |> gelu_new |> lin@c_proj D
  y <- x + m
  return y, present_kv

gpt2 :: TokenIds[B,S] -> ?Tensor[B,S] -> ?Cache -> ?Bool -> (Tensor[B,S,V], ?Cache)
gpt2 input_ids attn_mask past_key_values use_cache = do
  tok <- embedding@wte input_ids dim=D
  past_0 <- Cache.index past_key_values 0
  past_length <- Cache.seq_len past_0
  pos <- position_ids input_ids attention_mask=attn_mask past_length=past_length |> embedding@wpe
  x <- tok + pos
  present_key_values <- Cache.init
  for@h i <- [0..L) do
    past_i <- Cache.index past_key_values i
    x, present_i <- gpt2_block x attn_mask past_i use_cache
    present_key_values <- use_cache ? Cache.append present_key_values present_i : present_key_values
  logits <- layernorm@ln_f x |> linear@wte
  return logits, present_key_values
