T   = 1024   -- max sequence length
D   = 768    -- hidden dimensions
L   = 12     -- number of layers
H   = 12     -- number of attention heads
V   = 520257 -- vocab size

gpt2_block :: Tensor[B,S,D] -> ?Tensor[B,S] -> ?Cache -> ?Bool -> (Tensor[B,S,D], ?Cache)
gpt2_block x attn_mask past_kv use_cache = do
  q, k, v <- layernorm@ln_1 x |>
    linear@attn.c_attn out_features=3*D transpose=true bias=true |>
    split_last parts=3 |>
    reshape_heads_triplet heads=H
  k_all, v_all, present_kv <- cache::update past_kv k v when=use_cache
  k_ctx, v_ctx <- cache::coalesce k_all v_all k v
  causal_attn_mask <- causal_mask q key=k_ctx window=T padding_mask=attn_mask
  a <- attention q k_ctx v_ctx backend=sdpa causal=true mask=causal_attn_mask |>
    merge_heads |>
    linear@attn.c_proj out_features=D transpose=true bias=true
  x <- x + a
  m <- layernorm@ln_2 x |>
    linear@mlp.c_fc out_features=4*D transpose=true bias=true |>
    act::gelu_new |>
    linear@mlp.c_proj out_features=D transpose=true bias=true
  y <- x + m
  return y, present_kv

gpt2 :: TokenIds[B,S] -> ?Tensor[B,S] -> ?Cache -> ?Bool -> (Tensor[B,S,V], ?Cache)
gpt2 input_ids attn_mask past_key_values use_cache = do
  tok <- embedding@wte input_ids dim=D
  pos_ids <- arange_positions input_ids attention_mask=attn_mask
  pos <- embedding@wpe pos_ids dim=D
  x <- tok + pos
  present_key_values <- init_list()
  for@h i <- [0..L) do
    past_i <- index past_key_values i
    x, present_i <- gpt2_block x attn_mask past_i use_cache
    present_key_values <- append present_key_values present_i when=use_cache
  logits <- layernorm@ln_f x |>
    linear tie_weight=wte.weight
  return logits, present_key_values
