D    = 4096      -- hidden dimension
V    = 32000     -- vocabulary size
L    = 32        -- number of decoder layers
H    = 32        -- number of query attention heads
KVH  = 8         -- number of key/value heads
HD   = 128       -- per-head dimension
KVD  = 1024      -- key/value projection dimension (KVH * HD)
FFN  = 14336     -- feed-forward intermediate dimension
EPS  = 1e-05     -- RMSNorm epsilon
THETA = 10000.0  -- RoPE base theta
C    = 4096      -- sliding attention window

import Activations silu
import Cache past_length
import Cache

rms :: @Path -> Tensor[B,S,D] -> Tensor[B,S,D]
rms@path x = rmsnorm@path x eps=EPS

mistral_block :: Tensor[B,S,D] -> Tensor[B,S] -> ?Tensor[B,S] -> ?CacheLayer -> (Tensor[B,S,D], ?CacheLayer)
mistral_block x pos_ids attn_mask past_kv = do
  xn <- rms@input_layernorm x
  a, new_kv <- scope@self_attn do
    q <- linear@q_proj xn dim=D |> reshape_heads heads=H
    k <- linear@k_proj xn dim=KVD |> reshape_heads heads=KVH
    v <- linear@v_proj xn dim=KVD |> reshape_heads heads=KVH
    q, k <- rope_pair q k position_ids=pos_ids theta=THETA
    k, v, new_kv <- Cache.update past_kv k v
    k <- repeat k (H / KVH)
    v <- repeat v (H / KVH)
    mask <- causal_mask q k window=C padding_mask=attn_mask
    a <- attention q k v mask=mask |> merge_heads |> linear@o_proj dim=D
    return a, new_kv
  x <- x + a
  xn <- rms@post_attention_layernorm x
  m <- scope@mlp do
    g <- linear@gate_proj xn dim=FFN
    u <- linear@up_proj xn dim=FFN
    return g |> silu |> mul u |> linear@down_proj dim=D
  return x + m, new_kv

mistral_7b_v0_1 :: TokenIds[B,S] -> ?Tensor[B,S] -> ?Cache -> ?Bool -> (Tensor[B,S,V], ?Cache)
mistral_7b_v0_1 input_ids attn_mask past_kv use_cache = do
  pos_ids <- position_ids input_ids attn_mask past_length=(past_length past_kv)
  x, new_kv <- scope@model do
    x <- embedding@embed_tokens input_ids dim=D
    new_kv <- use_cache ? Cache.init : null
    for@layers i <- [0..L) do
      past_i <- Cache.index past_kv i
      x, new_i <- mistral_block x pos_ids attn_mask past_i
      new_kv <- Cache.append new_kv new_i
    x <- rms@norm x
    return x, new_kv
  logits <- linear@lm_head x dim=V
  return logits, new_kv
