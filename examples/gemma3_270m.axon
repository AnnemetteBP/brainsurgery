D   = 640                -- hidden dimension
V   = 262208             -- vocabulary size
L   = 18                 -- number of decoder layers
H   = 4                  -- number of query attention heads
KVH = 1                  -- number of key/value heads
QD  = 1024               -- q projection dimension (H * head_dim)
KVD = 256                -- k/v projection dimension (KVH * head_dim)
FFN = 2048               -- feed-forward intermediate dimension
ROPE_PERIOD = 6          -- periodicity for long-context rope/window schedule
THETA_BASE = 10000.0     -- base rope theta
THETA_LONG = 1000000.0   -- long-context rope theta
WIN_LOCAL = 512          -- local sliding-window size
WIN_LONG = 32768         -- long-context attention window size
ATTN_SCALE = 0.0625      -- attention scale (1 / sqrt(head_dim))
EMB_SCALE = 25.298221281347036 -- embedding scaling factor (sqrt(D))

import Activations gelu_pytorch_tanh
import Cache
import Cache past_length

rms :: @Path -> Tensor[B,S,D] -> Tensor[B,S,D]
rms@path x = rmsnorm@path x cast_float=true unit_offset=true

gemma3_block :: Tensor[B,S,D] -> I -> Tensor[B,S] -> ?Tensor[B,S] -> ?Cache -> (Tensor[B,S,D], ?Cache)
gemma3_block x i pos_ids attn_mask past_kv = do
  xn <- rms@input_layernorm x
  a, new_kv <- scope@self_attn do
    q <- linear@q_proj xn dim=QD |> reshape_heads heads=H |> rms@q_norm
    k <- linear@k_proj xn dim=KVD |> reshape_heads heads=KVH |> rms@k_norm
    v <- linear@v_proj xn dim=KVD |> reshape_heads heads=KVH
    theta <- THETA_BASE + (THETA_LONG - THETA_BASE) * (((i + 1) % ROPE_PERIOD) == 0)
    q, k <- rope_pair q k position_ids=pos_ids theta=theta
    k, v, new_kv <- Cache.update past_kv k v
    k <- repeat k (H / KVH)
    v <- repeat v (H / KVH)
    window <- WIN_LOCAL + (WIN_LONG - WIN_LOCAL) * (((i + 1) % ROPE_PERIOD) == 0)
    mask <- causal_mask q k window=window padding_mask=attn_mask
    a <- attention q k v mask=mask scale=ATTN_SCALE |> merge_heads |> linear@o_proj dim=D
    return a, new_kv
  a <- rms@post_attention_layernorm a
  x <- x + a
  xn <- rms@pre_feedforward_layernorm x
  m <- scope@mlp do
    g <- linear@gate_proj xn dim=FFN
    u <- linear@up_proj xn dim=FFN
    return gelu_pytorch_tanh g |> mul u |> linear@down_proj dim=D
  m <- rms@post_feedforward_layernorm m
  return x + m, new_kv

gemma3 :: TokenIds[B,S] -> ?Tensor[B,S] -> ?Cache -> ?Bool -> (Tensor[B,S,V], ?Cache)
gemma3 input_ids attn_mask past_kv use_cache = do
  pos_ids <- position_ids input_ids attn_mask past_length=(past_length past_kv)
  logits, new_kv <- scope@model do
    x <- embedding@embed_tokens input_ids dim=D scale=EMB_SCALE
    new_kv <- use_cache ? Cache.init : null
    for@layers i <- [0..L) do
      past_i <- Cache.index past_kv i
      x, new_i <- gemma3_block x i pos_ids attn_mask past_i
      new_kv <- Cache.append new_kv new_i
    logits <- rms@norm x |>
      linear@embed_tokens
    return logits, new_kv
  return logits, new_kv
